# Configuração geral do aplicativo
APP_NAME=ProjetoGC
# Nome do aplicativo

APP_ENV=development
# Ambiente de execução

APP_LOCALE=pt_BR
# Localidade padrão

APP_CURRENCY=BRL
# Moeda padrão

APP_DATE_FORMAT=dd/MM/yyyy
# Formato de data

APP_TIME_ZONE=America/Sao_Paulo
# Fuso horário

APP_LOG_LEVEL=INFO
# Nível de log

# Persistência de dados
PERSISTENCE_DIRECTORY=.criso
# Diretório de persistência

PERSISTENCE_FILENAME=dados
# Nome do arquivo de dados

PERSISTENCE_FILE_EXTENSION=ser
# Extensão do arquivo de persistência

PERSISTENCE_BACKUP_ENABLED=false
# Backup automático habilitado

PERSISTENCE_BACKUP_DIRECTORY=backup
# Diretório de backup

PERSISTENCE_BACKUP_INTERVAL_DAYS=7
# Intervalo de backup em dias

# Comportamento da interface
UI_THEME=light
# Tema da interface

UI_FONT_SIZE=14
# Tamanho da fonte

UI_MAX_RECENT_TRANSACTIONS=10
# Máximo de transações recentes exibidas

UI_SHOW_TOOLTIPS=true
# Exibir tooltips

# Regras de validação e negócio
ALLOW_NEGATIVE_BALANCE=false
# Permitir saldo negativo

DEFAULT_CATEGORY_NAME=Outros
# Categoria padrão

DEFAULT_TRANSFER_DESCRIPTION=Transferência entre caixas
# Descrição padrão para transferências

MAX_CATEGORY_NAME_LENGTH=50
# Limite de caracteres para nome de categoria

MAX_TRANSACTION_DESCRIPTION_LENGTH=120
# Limite de caracteres para descrição de transação

# Configuração de exportação
EXPORT_CSV_SEPARATOR=;
# Separador CSV

EXPORT_DIRECTORY=export
# Diretório de exportação

EXPORT_DEFAULT_FORMAT=csv
# Formato padrão de exportação

# Teste / debug
DEBUG_MODE=true
# Modo de depuração